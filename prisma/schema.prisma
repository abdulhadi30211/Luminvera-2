  name                  String
  slug                  String          @unique
  description           String?
  
  // Primary Colors
  primary               String          @default("#10b981")      // Main brand color
  primaryForeground     String          @default("#ffffff")
  primaryHover          String          @default("#059669")
  
  // Secondary Colors
  secondary             String          @default("#6b7280")
  secondaryForeground   String          @default("#ffffff")
  
  // Background Colors
  background            String          @default("#ffffff")
  foreground            String          @default("#0f172a")
  
  // Card Colors
  card                  String          @default("#ffffff")
  cardForeground        String          @default("#0f172a")
  
  // Accent Colors
  accent                String          @default("#f59e0b")
  accentForeground      String          @default("#ffffff")
  
  // Status Colors
  success               String          @default("#10b981")
  successForeground     String          @default("#ffffff")
  warning               String          @default("#f59e0b")
  warningForeground     String          @default("#ffffff")
  error                 String          @default("#ef4444")
  errorForeground       String          @default("#ffffff")
  info                  String          @default("#3b82f6")
  infoForeground        String          @default("#ffffff")
  
  // Muted Colors
  muted                 String          @default("#f1f5f9")
  mutedForeground       String          @default("#64748b")
  
  // Border & Input
  border                String          @default("#e2e8f0")
  input                 String          @default("#e2e8f0")
  ring                  String          @default("#10b981")
  
  // Gradient
  gradientFrom          String          @default("#10b981")
  gradientVia           String?         @default("#14b8a6")
  gradientTo            String          @default("#06b6d4")
  
