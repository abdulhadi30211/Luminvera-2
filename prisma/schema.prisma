// ============================================
// LUMINVERA - Enterprise Multi-Vendor E-Commerce
// Pakistan-First, Scalable Architecture
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS - Type Safety at Database Level
// ============================================

enum UserRole {
  USER
  SELLER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
  PENDING_VERIFICATION
}

enum SellerStatus {
  PENDING
  VERIFIED
  SUSPENDED
  BANNED
  REJECTED
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  LIVE
  DISABLED
  ARCHIVED
  REJECTED
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
  REFUNDED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  COD
  WALLET
  CARD
  BANK_TRANSFER
  JAZZ_CASH
  EASY_PAISA
}

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  RESOLVED_PARTIAL
  CLOSED
}

enum NotificationType {
  ORDER
  PAYMENT
  APPROVAL
  SUSPENSION
  PROMOTION
  SYSTEM
  DISPUTE
  REFUND
  PAYOUT
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
  BUY_X_GET_Y
}

// ============================================
// USER DOMAIN - Identity & Authentication
// ============================================

model User {
  id                    String          @id @default(uuid())
  email                 String          @unique
  emailVerified         Boolean         @default(false)
  emailVerifiedAt       DateTime?
  passwordHash          String
  
  // Profile
  firstName             String?
  lastName              String?
  phone                 String?
  phoneVerified         Boolean         @default(false)
  phoneVerifiedAt       DateTime?
  avatarUrl             String?
  
  // Role & Access (Database-Enforced)
  role                  UserRole        @default(USER)
  accountStatus         AccountStatus   @default(PENDING_VERIFICATION)
  
  // Security
  failedLoginAttempts   Int             @default(0)
  lockedUntil           DateTime?
  lastLoginAt           DateTime?
  lastLoginIp           String?
  
  // GDPR Compliance
  dataDeletionRequested Boolean         @default(false)
  dataDeletionRequestedAt DateTime?
  
  // Timestamps
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  sessions              Session[]
  loginHistories        LoginHistory[]
  addresses             Address[]
  carts                 Cart[]
  orders                Order[]
  reviews               Review[]
  wishlistItems         WishlistItem[]
  notifications         Notification[]
  sellerProfile         Seller?
  wallet                Wallet?
  refundWallet          RefundWallet?
  searchHistories       SearchHistory[]
  priceAlerts           PriceAlert[]
  stockAlerts           StockAlert[]
  recentlyViewed        RecentlyViewed[]
  disputes              Dispute[]       @relation("DisputeBuyer")
  supportTickets        SupportTicket[]

  @@index([email])
  @@index([role])
  @@index([accountStatus])
}

model Session {
  id                    String          @id @default(uuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tokenHash             String          @unique
  refreshTokenHash      String          @unique
  
  deviceInfo            String?
  ipAddress             String?
  userAgent             String?
  
  expiresAt             DateTime
  refreshExpiresAt      DateTime
  
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now())
  
  @@index([userId])
  @@index([tokenHash])
}

model LoginHistory {
  id                    String          @id @default(uuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  ipAddress             String?
  userAgent             String?
  deviceInfo            String?
  location              String?
  
  wasSuccessful         Boolean
  failureReason         String?
  wasSuspicious         Boolean         @default(false)
  
  createdAt             DateTime        @default(now())
  
  @@index([userId])
  @@index([createdAt])
}

model VerificationToken {
  id                    String          @id @default(uuid())
  email                 String
  token                 String          @unique
  
  type                  String          // 'email_verification', 'password_reset', 'phone_otp'
  expiresAt             DateTime
  
  used                  Boolean         @default(false)
  createdAt             DateTime        @default(now())
  
  @@index([email])
  @@index([token])
}

// ============================================
// ADDRESS SYSTEM - Multi-Location Support
// ============================================

model Address {
  id                    String          @id @default(uuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  label                 String?         // Home, Work, etc.
  recipientName         String
  recipientPhone        String
  
  country               String          @default("Pakistan")
  province              String
  city                  String
  area                  String?
  streetAddress         String
  postalCode            String?
  
  isDefault             Boolean         @default(false)
  
  latitude              Float?
  longitude             Float?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([userId])
}

// ============================================
// SELLER DOMAIN - Business & Compliance
// ============================================

model Seller {
  id                    String          @id @default(uuid())
  userId                String          @unique
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Business Identity
  storeName             String
  storeSlug             String          @unique
  storeDescription      String?
  storeLogoUrl          String?
  storeBannerUrl        String?
  
  // Business Verification
  businessName          String?
  businessType          String?         // Individual, Company
  cnicNumber            String?         // National ID
  ntnNumber             String?         // National Tax Number
  businessRegNumber     String?
  businessDocUrl        String?
  
  // Verification Status
  status                SellerStatus    @default(PENDING)
  verificationNotes     String?
  verifiedAt            DateTime?
  verifiedBy            String?         // Admin ID
  
  // Contact
  businessPhone         String?
  businessEmail         String?
  
  // Banking
  bankName              String?
  bankAccountTitle      String?
  bankAccountNumber     String?
  iban                  String?
  jazzCashNumber        String?
  easypaisaNumber       String?
  
  // Store Policies
  returnPolicy          String?
  shippingPolicy        String?
  warrantyPolicy        String?
  
  // Agreement
  sellerAgreementAccepted Boolean       @default(false)
  sellerAgreementAcceptedAt DateTime?
  
  // Seller Metrics
  totalSales            Int             @default(0)
  totalOrders           Int             @default(0)
  totalProducts         Int             @default(0)
  averageRating         Float           @default(0)
  totalReviews          Int             @default(0)
  
  // SLA & Risk
  onTimeShippingRate    Float           @default(0)
  cancellationRate      Float           @default(0)
  returnRate            Float           @default(0)
  riskScore             Float           @default(0)
  
  // Financial
  commissionRate        Float           @default(10) // Percentage
  totalEarnings         Float           @default(0)
  availableBalance      Float           @default(0)
  pendingBalance        Float           @default(0)
  
  // Flags
  isFeatured            Boolean         @default(false)
  isTopSeller           Boolean         @default(false)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  products              Product[]
  orders                Order[]         @relation("SellerOrder")
  orderItems            OrderItem[]
  sellerPayouts         SellerPayout[]
  sellerWarnings        SellerWarning[]
  productApprovals      ProductApproval[]
  disputes              Dispute[]       @relation("DisputeSeller")
  
  @@index([storeSlug])
  @@index([status])
}

model SellerWarning {
  id                    String          @id @default(uuid())
  sellerId              String
  seller                Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  reason                String
  description           String?
  
  issuedBy              String          // Admin ID
  isActive              Boolean         @default(true)
  
  createdAt             DateTime        @default(now())
  
  @@index([sellerId])
}

// ============================================
// CATEGORY SYSTEM - Hierarchical
// ============================================

model Category {
  id                    String          @id @default(uuid())
  name                  String
  slug                  String          @unique
  description           String?
  imageUrl              String?
  iconUrl               String?
  
  // Hierarchy
  parentId              String?
  parent                Category?       @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children              Category[]      @relation("CategoryHierarchy")
  
  // Display
  sortOrder             Int             @default(0)
  isActive              Boolean         @default(true)
  isFeatured            Boolean         @default(false)
  
  // Commission
  defaultCommission     Float           @default(10)
  
  // SEO
  metaTitle             String?
  metaDescription       String?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  products              Product[]
  attributes            CategoryAttribute[]
  
  @@index([slug])
  @@index([parentId])
}

// ============================================
// ATTRIBUTE SYSTEM - Dynamic Product Attributes
// ============================================

model Attribute {
  id                    String          @id @default(uuid())
  name                  String
  slug                  String          @unique
  type                  String          // text, number, select, multiselect, color
  
  isFilterable          Boolean         @default(true)
  isRequired            Boolean         @default(false)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  values                AttributeValue[]
  categories            CategoryAttribute[]
  productAttributes     ProductAttribute[]
}

model AttributeValue {
  id                    String          @id @default(uuid())
  attributeId           String
  attribute             Attribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  
  value                 String
  slug                  String
  colorCode             String?         // For color attributes
  
  sortOrder             Int             @default(0)
  
  createdAt             DateTime        @default(now())
  
  @@unique([attributeId, slug])
  @@index([attributeId])
}

model CategoryAttribute {
  id                    String          @id @default(uuid())
  categoryId            String
  category              Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributeId           String
  attribute             Attribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  
  isRequired            Boolean         @default(false)
  isFilterable          Boolean         @default(true)
  sortOrder             Int             @default(0)
  
  @@unique([categoryId, attributeId])
}

// ============================================
// PRODUCT DOMAIN - Catalog Management
// ============================================

model Product {
  id                    String          @id @default(uuid())
  sellerId              String
  seller                Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  // Basic Info
  sku                   String          @unique
  name                  String
  slug                  String          @unique
  description           String?
  shortDescription      String?
  
  // Categorization
  categoryId            String?
  category              Category?       @relation(fields: [categoryId], references: [id])
  
  // Status
  status                ProductStatus   @default(DRAFT)
  approvalNotes         String?
  approvedAt            DateTime?
  approvedBy            String?
  
  // Media
  primaryImageUrl       String?
  images                String?         // JSON array of image URLs
  videos                String?         // JSON array of video URLs
  
  // Pricing
  basePrice             Float
  costPrice             Float?
  compareAtPrice        Float?          // Original/MRP price
  currency              String          @default("PKR")
  
  // Discount
  discountPercentage    Float           @default(0)
  discountAmount        Float           @default(0)
  discountStartsAt      DateTime?
  discountEndsAt        DateTime?
  
  // Tax
  taxRate               Float           @default(0)
  taxIncluded           Boolean         @default(true)
  
  // Inventory
  stockQuantity         Int             @default(0)
  stockReserved         Int             @default(0)
  stockSold             Int             @default(0)
  lowStockThreshold     Int             @default(10)
  trackInventory        Boolean         @default(true)
  allowBackorder        Boolean         @default(false)
  
  // Dimensions & Weight
  weight                Float?          // in kg
  length                Float?          // in cm
  width                 Float?          // in cm
  height                Float?          // in cm
  
  // Shipping
  freeShipping          Boolean         @default(false)
  shippingFee           Float           @default(0)
  
  // Variants
  hasVariants           Boolean         @default(false)
  variantAttributes     String?         // JSON array: ["color", "size"]
  
  // SEO
  metaTitle             String?
  metaDescription       String?
  metaKeywords          String?
  
  // Metrics
  viewCount             Int             @default(0)
  purchaseCount         Int             @default(0)
  wishlistCount         Int             @default(0)
  averageRating         Float           @default(0)
  totalReviews          Int             @default(0)
  
  // Flags
  isFeatured            Boolean         @default(false)
  isNewArrival          Boolean         @default(false)
  isBestSeller          Boolean         @default(false)
  isFlashSale           Boolean         @default(false)
  
  // Warranty
  warrantyPeriod        String?         // e.g., "12 months"
  warrantyType          String?         // "brand", "seller"
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  variants              ProductVariant[]
  productAttributes     ProductAttribute[]
  orderItems            OrderItem[]
  reviews               Review[]
  wishlistItems         WishlistItem[]
  recentlyViewed        RecentlyViewed[]
  priceHistory          ProductPriceHistory[]
  stockAlerts           StockAlert[]
  priceAlerts           PriceAlert[]
  cartItems             CartItem[]
  
  @@index([sku])
  @@index([slug])
  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
}

model ProductVariant {
  id                    String          @id @default(uuid())
  productId             String
  product               Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  sku                   String          @unique
  barcode               String?
  
  // Variant Attributes (JSON: {"color": "red", "size": "L"})
  attributes            String
  
  // Pricing
  priceAdjustment       Float           @default(0) // + or - from base
  compareAtPrice        Float?
  
  // Inventory
  stockQuantity         Int             @default(0)
  stockReserved         Int             @default(0)
  
  // Media
  imageUrl              String?
  
  isActive              Boolean         @default(true)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  cartItems             CartItem[]
  orderItems            OrderItem[]
  
  @@index([productId])
  @@index([sku])
}

model ProductAttribute {
  id                    String          @id @default(uuid())
  productId             String
  product               Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeId           String
  attribute             Attribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  
  value                 String
  
  createdAt             DateTime        @default(now())
  
  @@unique([productId, attributeId])
}

model ProductPriceHistory {
  id                    String          @id @default(uuid())
  productId             String
  product               Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  oldPrice              Float
  newPrice              Float
  reason                String?         // "discount", "price_update", "flash_sale"
  
  changedBy             String?         // User ID
  
  createdAt             DateTime        @default(now())
  
  @@index([productId])
}

model ProductApproval {
  id                    String          @id @default(uuid())
  productId            String
  sellerId             String
  seller               Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  action               String          // "approved", "rejected", "requested_changes"
  notes                String?
  
  reviewedBy           String?         // Admin ID
  reviewedAt           DateTime?
  
  createdAt            DateTime        @default(now())
  
  @@index([productId])
  @@index([sellerId])
}

// ============================================
// CART SYSTEM
// ============================================

model Cart {
  id                    String          @id @default(uuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Guest cart support
  guestId               String?         @unique
  
  // Totals (cached for performance)
  subtotal              Float           @default(0)
  discount              Float           @default(0)
  deliveryFee           Float           @default(0)
  tax                   Float           @default(0)
  total                 Float           @default(0)
  
  // Applied coupon
  appliedCouponId       String?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  items                 CartItem[]
  
  @@index([userId])
  @@index([guestId])
}

model CartItem {
  id                    String          @id @default(uuid())
  cartId                String
  cart                  Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  productId             String
  product               Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId             String?
  variant               ProductVariant? @relation(fields: [variantId], references: [id])
  
  quantity              Int             @default(1)
  
  // Price snapshot (at time of adding)
  unitPrice             Float
  totalPrice            Float
  
  // Seller for this item
  sellerId              String
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
}

// ============================================
// ORDER DOMAIN - Full Order Lifecycle
// ============================================

model Order {
  id                    String          @id @default(uuid())
  orderNumber           String          @unique
  
  // Customer
  userId                String
  user                  User            @relation(fields: [userId], references: [id])
  
  // Seller (for split orders, each seller gets separate order)
  sellerId              String?
  seller                Seller?         @relation("SellerOrder", fields: [sellerId], references: [id])
  
  // Parent order (for split orders)
  parentOrderId         String?
  
  // Shipping Address (snapshot)
  shippingRecipientName String
  shippingPhone         String
  shippingCountry       String
  shippingProvince      String
  shippingCity          String
  shippingArea          String?
  shippingStreetAddress String
  shippingPostalCode    String?
  
  // Status
  status                OrderStatus     @default(PLACED)
  statusHistory         String?         // JSON array of status changes
  
  // Pricing
  subtotal              Float
  discount              Float           @default(0)
  couponDiscount        Float           @default(0)
  deliveryFee           Float           @default(0)
  tax                   Float           @default(0)
  total                 Float
  
  // Payment
  paymentMethod         PaymentMethod
  paymentStatus         PaymentStatus   @default(PENDING)
  paymentReference      String?
  paidAt                DateTime?
  
  // COD specific
  codAmount             Float?
  codCollected          Boolean         @default(false)
  codCollectedAt        DateTime?
  
  // Timeline
  placedAt              DateTime        @default(now())
  confirmedAt           DateTime?
  packedAt              DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  
  // Delivery
  estimatedDeliveryDate DateTime?
  actualDeliveryDate    DateTime?
  
  // Courier
  courierName           String?
  courierTrackingNumber String?
  courierTrackingUrl    String?
  
  // Notes
  customerNotes         String?
  sellerNotes           String?
  adminNotes            String?
  
  // Invoice
  invoiceNumber         String?
  invoiceUrl            String?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  items                 OrderItem[]
  payments              Payment[]
  disputes              Dispute[]       @relation("DisputeOrder")
  refund                Refund?
  
  @@index([orderNumber])
  @@index([userId])
  @@index([sellerId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id                    String          @id @default(uuid())
  orderId               String
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId             String
  product               Product         @relation(fields: [productId], references: [id])
  variantId             String?
  variant               ProductVariant? @relation(fields: [variantId], references: [id])
  
  sellerId              String
  seller                Seller          @relation(fields: [sellerId], references: [id])
  
  // Product Snapshot (at time of order)
  productName           String
  productSku            String
  productImageUrl       String?
  variantAttributes     String?         // JSON
  
  // Pricing
  unitPrice             Float
  quantity              Int
  totalPrice            Float
  
  // Commission
  commissionRate        Float
  commissionAmount      Float
  sellerEarnings        Float
  
  // Status
  itemStatus            OrderStatus     @default(PLACED)
  
  // Delivery
  deliveredAt           DateTime?
  
  createdAt             DateTime        @default(now())
  
  @@index([orderId])
  @@index([productId])
  @@index([sellerId])
}

// ============================================
// PAYMENT DOMAIN
// ============================================

model Payment {
  id                    String          @id @default(uuid())
  orderId               String
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Payment Details
  paymentMethod         PaymentMethod
  amount                Float
  
  // Transaction
  transactionId         String?
  gatewayReference      String?
  gatewayResponse       String?         // JSON
  
  // Status
  status                PaymentStatus   @default(PENDING)
  failureReason         String?
  
  // Timestamps
  initiatedAt           DateTime        @default(now())
  completedAt           DateTime?
  failedAt              DateTime?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([orderId])
  @@index([transactionId])
}

model Refund {
  id                    String          @id @default(uuid())
  orderId               String          @unique
  order                 Order           @relation(fields: [orderId], references: [id])
  
  amount                Float
  reason                String
  
  status                PaymentStatus   @default(PENDING)
  
  processedAt           DateTime?
  processedBy           String?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([orderId])
}

// ============================================
// WALLET SYSTEM
// ============================================

model Wallet {
  id                    String          @id @default(uuid())
  userId                String          @unique
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  balance               Float           @default(0)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  transactions          WalletTransaction[]
  
  @@index([userId])
}

model WalletTransaction {
  id                    String          @id @default(uuid())
  walletId              String
  wallet                Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  type                  String          // "credit", "debit"
  amount                Float
  balanceAfter          Float
  
  reference             String?         // Order ID, Refund ID, etc.
  description           String?
  
  createdAt             DateTime        @default(now())
  
  @@index([walletId])
  @@index([reference])
}

model RefundWallet {
  id                    String          @id @default(uuid())
  userId                String          @unique
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  balance               Float           @default(0)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  transactions          RefundWalletTransaction[]
  
  @@index([userId])
}

model RefundWalletTransaction {
  id                    String          @id @default(uuid())
  refundWalletId        String
  refundWallet          RefundWallet    @relation(fields: [refundWalletId], references: [id], onDelete: Cascade)
  
  type                  String          // "credit", "debit"
  amount                Float
  balanceAfter          Float
  
  reference             String?
  description           String?
  
  createdAt             DateTime        @default(now())
  
  @@index([refundWalletId])
}

model SellerPayout {
  id                    String          @id @default(uuid())
  sellerId              String
  seller                Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  amount                Float
  status                PaymentStatus   @default(PENDING)
  
  periodStart           DateTime
  periodEnd             DateTime
  
  // Bank details snapshot
  bankName              String?
  bankAccountNumber     String?
  
  processedAt           DateTime?
  processedBy           String?
  transactionReference  String?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([sellerId])
  @@index([status])
}

// ============================================
// DISPUTE & RETURNS
// ============================================

model Dispute {
  id                    String          @id @default(uuid())
  disputeNumber         String          @unique
  
  orderId               String
  order                 Order           @relation("DisputeOrder", fields: [orderId], references: [id])
  
  buyerId               String
  buyer                 User            @relation("DisputeBuyer", fields: [buyerId], references: [id])
  
  sellerId              String
  seller                Seller          @relation("DisputeSeller", fields: [sellerId], references: [id])
  
  type                  String          // "return", "refund", "replacement", "complaint"
  reason                String
  description           String?
  
  status                DisputeStatus   @default(OPEN)
  
  // Resolution
  resolutionType        String?         // "full_refund", "partial_refund", "replacement", "rejected"
  resolutionAmount      Float?
  resolutionNotes       String?
  
  resolvedBy            String?
  resolvedAt            DateTime?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  messages              DisputeMessage[]
  
  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model DisputeMessage {
  id                    String          @id @default(uuid())
  disputeId             String
  dispute               Dispute         @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  
  senderId              String
  senderRole            String          // "buyer", "seller", "admin"
  
  message               String
  attachments           String?         // JSON array of URLs
  
  createdAt             DateTime        @default(now())
  
  @@index([disputeId])
}

