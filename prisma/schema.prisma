// ============================================
// PLATFORM SERVICES - 100+ Services Management
// ============================================

enum ServiceCategory {
  PAYMENT
  SHIPPING
  COMMUNICATION
  ANALYTICS
  SECURITY
  MARKETING
  SOCIAL
  STORAGE
  AI_ML
  NOTIFICATION
  VERIFICATION
  COMPLIANCE
  SUPPORT
  INTEGRATION
  AUTOMATION
  BACKUP
  MONITORING
  CDN
  EMAIL
  SMS
  CRM
  ERP
  ACCOUNTING
  INVENTORY
  RECOMMENDATION
  SEARCH
  CACHE
  AUTHENTICATION
  FRAUD_DETECTION
  LOYALTY
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DEPRECATED
  COMING_SOON
}

model PlatformService {
  id                    String          @id @default(uuid())
  
  // Basic Info
  name                  String
  slug                  String          @unique
  description           String?
  icon                  String?         // Icon name or URL
  category              ServiceCategory
  
  // Provider Info
  provider              String          // e.g., "Stripe", "JazzCash", "Leopards"
  providerUrl           String?
  
  // Configuration
  configSchema          String?         // JSON schema for configuration
  config                String?         // JSON encrypted config
  
  // Status & Visibility
  status                ServiceStatus   @default(ACTIVE)
  isEnabled             Boolean         @default(false)
  isPublic              Boolean         @default(true)  // Visible to users?
  isPremium             Boolean         @default(false) // Premium feature?
  
  // Pricing
  pricingModel          String?         // "free", "usage_based", "subscription", "hybrid"
  pricePerUnit          Float?
  monthlyFee            Float?
  
  // Capabilities
  capabilities          String?         // JSON array of capabilities
  
  // API Details
  apiVersion            String?
  apiEndpoint           String?
  apiKey                String?         // Encrypted
  apiSecret             String?         // Encrypted
  
  // Integration
  integrationGuide      String?         // URL to integration guide
  webhookUrl            String?
  
  // Coverage (for shipping, payment, etc.)
  supportedCountries    String?         // JSON array
  supportedCurrencies   String?         // JSON array
  
  // Metrics
  totalUsage            Int             @default(0)
  successRate           Float           @default(100)
  avgResponseTime       Int             @default(0)  // in ms
  
  // Admin
  addedBy               String?
  lastModifiedBy        String?
  notes                 String?
  
  sortOrder             Int             @default(0)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  usageLogs             ServiceUsageLog[]
  
  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([isEnabled])
}

model ServiceUsageLog {
  id                    String          @id @default(uuid())
  serviceId             String
  service               PlatformService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  userId                String?
  orderId               String?
  
  action                String
  requestPayload        String?         // JSON (sanitized)
  responsePayload       String?         // JSON (sanitized)
  
  isSuccess             Boolean         @default(true)
  errorMessage          String?
  
  responseTime          Int             // in ms
  
  ipAddress             String?
  
  createdAt             DateTime        @default(now())
  
  @@index([serviceId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// PLATFORM FEATURES - Feature Toggle System
// ============================================

enum FeatureType {
  TOGGLE
  GRADUAL_ROLLOUT
  SCHEDULED
  SEGMENTED
  PREMIUM
  BETA
  EXPERIMENTAL
}

model PlatformFeature {
  id                    String          @id @default(uuid())
  
  // Basic Info
  name                  String
  key                   String          @unique
  description           String?
  icon                  String?
  
  // Feature Type
  type                  FeatureType     @default(TOGGLE)
  
  // Status
  isEnabled             Boolean         @default(false)
  isPublic              Boolean         @default(true)
  
  // Gradual Rollout
  rolloutPercentage     Float           @default(0)
  
  // Targeting
  targetRoles           String?         // JSON array of user roles
  targetPlans           String?         // JSON array of subscription plans
  targetRegions         String?         // JSON array of regions
  targetUsers           String?         // JSON array of specific user IDs
  
  // Schedule
  scheduledStart        DateTime?
  scheduledEnd          DateTime?
  
  // Dependencies
  dependsOn             String?         // JSON array of feature keys
  
  // Metrics
  usageCount            Int             @default(0)
  
  // Metadata
  category              String?         // "UI", "Security", "Performance", "Commerce"
  tags                  String?         // JSON array
  
  // Admin
  addedBy               String?
  lastModifiedBy        String?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([key])
  @@index([isEnabled])
}

// ============================================
// ADMIN TOOLS - Platform Management Tools
// ============================================

enum ToolCategory {
  DATA_MANAGEMENT
  USER_MANAGEMENT
  PRODUCT_MANAGEMENT
  ORDER_MANAGEMENT
  FINANCIAL
  MARKETING
  ANALYTICS
  SECURITY
  AUTOMATION
  COMMUNICATION
  IMPORT_EXPORT
  BACKUP_RESTORE
  BULK_OPERATIONS
  REPORTING
  MODERATION
  CONFIGURATION
  DEVELOPER
}

model AdminTool {
  id                    String          @id @default(uuid())
  
  // Basic Info
  name                  String
  slug                  String          @unique
  description           String?
  icon                  String?
  
  // Categorization
  category              ToolCategory
  tags                  String?         // JSON array
  
  // Execution
  executeEndpoint       String?         // API endpoint to execute
  executeMethod         String          @default("POST")
  parameters            String?         // JSON schema for parameters
  
  // Permissions
  requiredRole          String          @default("ADMIN")  // ADMIN, SUPER_ADMIN
  
  // Status
  isEnabled             Boolean         @default(true)
  isDangerous           Boolean         @default(false)  // Destructive operation?
  requiresConfirmation  Boolean         @default(true)
  
  // Scheduling
  isSchedulable         Boolean         @default(false)
  defaultSchedule       String?         // Cron expression
  
  // History
  lastExecutedAt        DateTime?
  lastExecutedBy        String?
  executionCount        Int             @default(0)
  
  // Documentation
  documentation         String?         // Markdown docs
  helpUrl               String?
  
  sortOrder             Int             @default(0)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // Relations
  executionLogs         ToolExecutionLog[]
  
  @@index([slug])
  @@index([category])
  @@index([isEnabled])
}

model ToolExecutionLog {
  id                    String          @id @default(uuid())
  toolId                String
  tool                  AdminTool       @relation(fields: [toolId], references: [id], onDelete: Cascade)
  
  executedBy            String
  
  parameters            String?         // JSON
  result                String?         // JSON
  
  isSuccess             Boolean         @default(true)
  errorMessage          String?
  
  executionTime         Int             // in ms
  
  createdAt             DateTime        @default(now())
  
  @@index([toolId])
  @@index([executedBy])
  @@index([createdAt])
}

// ============================================
// COLOR PALETTE - Dynamic Theme Management
// ============================================

model ColorPalette {
