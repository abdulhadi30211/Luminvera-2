}

// ============================================
// EMAIL TEMPLATES
// ============================================

model EmailTemplate {
  id                    String          @id @default(uuid())
  
  // Template Info
  name                  String
  type                  String          // order_confirmation, shipping, welcome, etc.
  
  // Content
  subject               String
  body                  String
  variables             String          // JSON array of variable names
  
  // Status
  isActive              Boolean         @default(true)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([type])
  @@index([isActive])
}
