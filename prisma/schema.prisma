  darkForeground        String          @default("#f8fafc")
  darkCard              String          @default("#1e293b")
  darkCardForeground    String          @default("#f8fafc")
  darkMuted             String          @default("#334155")
  darkMutedForeground   String          @default("#94a3b8")
  darkBorder            String          @default("#334155")
  
  // Status
  isActive              Boolean         @default(false)
  isDefault             Boolean         @default(false)
  isPublic              Boolean         @default(true)
  
  // Meta
  tags                  String?         // JSON array
  previewUrl            String?
  
  createdBy             String?
  lastModifiedBy        String?
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([slug])
  @@index([isActive])
}

